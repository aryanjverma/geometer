# Firebase — copy to .env and fill in your project values
VITE_FIREBASE_API_KEY=
# Use your Firebase Hosting domain (e.g. <project>.web.app), NOT <project>.firebaseapp.com.
# This keeps the app and the auth helper on the same origin, which avoids the
# "missing initial state" sign-in error on mobile / storage-partitioned browsers.
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
